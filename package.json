{
  "name": "luguel-backend",
  "version": "1.0.0",
  "description": "Backend DDD para plataforma universal de aluguel.",
  "main": "dist/interfaces/http/server.js",
  "scripts": {
    "dev": "node --watch --import tsx src/interfaces/http/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "vercel-build": "npm run prisma:generate && npm run build",
    "start": "node dist/interfaces/http/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [
    "ddd",
    "fastify",
    "prisma",
    "postgres",
    "redis"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  }
}
