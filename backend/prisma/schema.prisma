generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  LOCADOR
  LOCATARIO
  ADMIN
}

enum ListingStatus {
  ACTIVE
  PENDING_VALIDATION
  FLAGGED
  SUSPENDED
  ARCHIVED
}

enum ListingDeliveryMode {
  PICKUP
  DELIVERY
  BOTH
}

enum ListingBookingMode {
  IMMEDIATE
  SCHEDULED
  BOTH
}

enum RentalStatus {
  REQUESTED
  APPROVED
  ACTIVE
  COMPLETED
  CANCELED
  DISPUTED
}

enum RentalPaymentMode {
  IN_APP_FULL
  SPLIT_SIGNAL_REMAINDER
}

enum RentalPaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum RentalFulfillmentMethod {
  PICKUP_LOCAL
  DELIVERY_PARTNER
  DELIVERY_OWNER
}

enum ReportStatus {
  OPEN
  TRIAGED
  RESOLVED
  REJECTED
}

enum BoostStatus {
  PENDING
  PAID
  ACTIVE
  EXPIRED
  CANCELED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IdentityVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserPlan {
  FREE
  PREMIUM
}

enum PremiumSubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum ListingAvailabilityStatus {
  FREE
  BLOCKED
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  emailVerified   Boolean          @default(false)
  image           String?
  name            String
  role            UserRole         @default(LOCATARIO)
  isBanned        Boolean          @default(false)
  bannedAt        DateTime?
  reputationScore Int              @default(0)
  identityVerificationStatus IdentityVerificationStatus @default(PENDING)
  identityVerifiedAt DateTime?
  plan            UserPlan         @default(FREE)
  planExpiresAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  listings        Listing[]        @relation("OwnerListings")
  rentals         Rental[]         @relation("TenantRentals")
  reviewsWritten  Review[]         @relation("ReviewerReviews")
  reviewsReceived Review[]         @relation("ReviewedReviews")
  reports         Report[]         @relation("ReporterReports")
  adminLogs       AdminAuditLog[]  @relation("AdminAuditLogs")
  riskAssessments RiskAssessment[] @relation("UserRiskAssessments")
  rentalChatMessages RentalChatMessage[] @relation("RentalChatMessages")
  identityVerification UserIdentityVerification?
  premiumSubscriptions PremiumSubscription[]
  sessions        Session[]
  accounts        Account[]
}

model Listing {
  id                 String                    @id @default(uuid())
  ownerId            String
  title              String
  description        String
  category           String?
  city               String?
  region             String?
  dailyPrice         Decimal                   @db.Decimal(10, 2)
  deliveryMode       ListingDeliveryMode       @default(BOTH)
  bookingMode        ListingBookingMode        @default(BOTH)
  status             ListingStatus             @default(ACTIVE)
  riskLevel          RiskLevel                 @default(LOW)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  owner              User                      @relation("OwnerListings", fields: [ownerId], references: [id], onDelete: Cascade)
  rentals            Rental[]
  reviews            Review[]
  reports            Report[]
  boosts             Boost[]
  availabilitySlots  ListingAvailabilitySlot[]
  riskAssessments    RiskAssessment[]          @relation("ListingRiskAssessments")
}

model ListingAvailabilitySlot {
  id          String                   @id @default(uuid())
  listingId   String
  date        DateTime
  status      ListingAvailabilityStatus
  pickupTime  String?
  returnTime  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  listing     Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId, date])
}

model Rental {
  id          String       @id @default(uuid())
  listingId   String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  totalPrice  Decimal      @db.Decimal(10, 2)
  fulfillmentMethod RentalFulfillmentMethod @default(PICKUP_LOCAL)
  deliveryAddress String?
  platformFee Decimal     @db.Decimal(10, 2) @default(0)
  depositAmount Decimal   @db.Decimal(10, 2) @default(0)
  signalAmount Decimal    @db.Decimal(10, 2) @default(0)
  remainderAmount Decimal @db.Decimal(10, 2) @default(0)
  status      RentalStatus @default(REQUESTED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  listing     Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant      User         @relation("TenantRentals", fields: [tenantId], references: [id], onDelete: Cascade)
  reviews     Review[]
  reports     Report[]
  payment     RentalPayment?
  contract    RentalContract?
  receipt     RentalReceipt?
  chatMessages RentalChatMessage[]
}

model Review {
  id         String   @id @default(uuid())
  listingId  String
  rentalId   String
  reviewerId String
  reviewedId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rental     Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed   User     @relation("ReviewedReviews", fields: [reviewedId], references: [id], onDelete: Cascade)

  @@unique([rentalId, reviewerId])
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  listingId  String?
  rentalId   String?
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  riskLevel  RiskLevel    @default(MEDIUM)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reporter   User         @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  listing    Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  rental     Rental?      @relation(fields: [rentalId], references: [id], onDelete: SetNull)
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User?    @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull)
}

model Boost {
  id        String      @id @default(uuid())
  listingId String
  status    BoostStatus @default(PENDING)
  amount    Decimal     @db.Decimal(10, 2)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  listing   Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model RiskAssessment {
  id        String    @id @default(uuid())
  userId    String?
  listingId String?
  score     Int
  level     RiskLevel
  reasons   Json
  createdAt DateTime  @default(now())
  user      User?     @relation("UserRiskAssessments", fields: [userId], references: [id], onDelete: SetNull)
  listing   Listing?  @relation("ListingRiskAssessments", fields: [listingId], references: [id], onDelete: SetNull)
}

model UserIdentityVerification {
  id                 String                     @id @default(uuid())
  userId             String                     @unique
  documentType       String
  documentNumberHash String
  fullName           String
  birthDate          DateTime
  status             IdentityVerificationStatus @default(PENDING)
  notes              String?
  submittedAt        DateTime                   @default(now())
  reviewedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PremiumSubscription {
  id        String                  @id @default(uuid())
  userId    String
  status    PremiumSubscriptionStatus @default(ACTIVE)
  amount    Decimal                 @db.Decimal(10, 2)
  months    Int
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RentalPayment {
  id                    String             @id @default(uuid())
  rentalId              String             @unique
  mode                  RentalPaymentMode
  status                RentalPaymentStatus @default(PENDING)
  totalAmount           Decimal            @db.Decimal(10, 2)
  platformFeeAmount     Decimal            @db.Decimal(10, 2)
  depositAmount         Decimal            @db.Decimal(10, 2)
  signalAmount          Decimal            @db.Decimal(10, 2)
  remainderAmount       Decimal            @db.Decimal(10, 2)
  paidAmount            Decimal            @db.Decimal(10, 2) @default(0)
  inAppPaymentReference String?
  proofUrl              String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  rental                Rental             @relation(fields: [rentalId], references: [id], onDelete: Cascade)
}

model RentalContract {
  id                 String   @id @default(uuid())
  rentalId           String   @unique
  termsVersion       String
  contractText       String
  checksum           String
  acceptedByTenantAt DateTime?
  acceptedByOwnerAt  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  rental             Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
}

model RentalReceipt {
  id            String   @id @default(uuid())
  rentalId      String   @unique
  receiptNumber String   @unique
  issuedAt      DateTime @default(now())
  payload       Json
  createdAt     DateTime @default(now())
  rental        Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
}

model RentalChatMessage {
  id        String   @id @default(uuid())
  rentalId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  rental    Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  sender    User     @relation("RentalChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([rentalId, createdAt])
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
